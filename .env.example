# ====================================
# جمعية تآزر - متغيرات البيئة
# ====================================
# انسخ هذا الملف إلى .env.local وأملأ القيم

# ====================================
# قاعدة البيانات MySQL
# ====================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=tazur_user
DB_PASSWORD=your_strong_password_here
DB_NAME=tazur_cardz

# ====================================
# NextAuth - المصادقة
# ====================================
# قم بتوليد قيمة عشوائية قوية (32+ حرف):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your_32_char_random_secret_here

# عنوان الموقع (في الإنتاج: https://yourdomain.com)
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ====================================
# Google OAuth
# ====================================
# للحصول على credentials:
# 1. اذهب إلى: https://console.cloud.google.com
# 2. أنشئ مشروعاً جديداً
# 3. فعّل Google OAuth API
# 4. أنشئ OAuth Client ID (Web Application)
# 5. أضف Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=placeholder_for_google_client_id
GOOGLE_CLIENT_SECRET=placeholder_for_google_client_secret

# ====================================
# الأمان
# ====================================
# ملح لتشفير عناوين IP (سلسلة عشوائية)
IP_HASH_SALT=your_random_salt_here

# ====================================
# ملاحظات مهمة
# ====================================
# - لا ترفع هذا الملف (.env.local) إلى Git
# - استخدم قيم قوية وعشوائية في الإنتاج
# - في Docker: ضع هذه القيم في docker-compose.yml أو .env
